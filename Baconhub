    local d, s, p; g.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then d = true; s = i.Position; p = g.Position end end)
    U.InputChanged:Connect(function(i) if d and i.UserInputType == Enum.UserInputType.MouseMovement then local e = i.Position - s; g.Position = UDim2.new(p.X.Scale, p.X.Offset + e.X, p.Y.Scale, p.Y.Offset + e.Y) end end)
    U.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then d = false end end)
end


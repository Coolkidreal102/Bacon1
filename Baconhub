    b.BackgroundColor3 = Color3.fromRGB(30,30,30); b.Text = txt; b.TextColor3 = Color3.new(1,1,1)
    b.Font = Enum.Font.GothamBold; b.TextSize = 12; Instance.new("UICorner", b); b.MouseButton1Click:Connect(callback)
    return b
end


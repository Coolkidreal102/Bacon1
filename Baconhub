-- // DRAGGING FIX //
local function EnableDrag(gui)
    local dragging, dragStart, startPos
    gui.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; dragStart = input.Position; startPos = gui.Position end
    end)
    UIS.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            gui.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UIS.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
end
EnableDrag(Main); EnableDrag(SideBox)

-- // RAW FLING LOGIC //
local function GetNearest()
    local closest, dist = nil, 100
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local d = (LocalPlayer.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
            if d < dist then dist = d; closest = p.Character end
        end
    end
    return closest
end

local function RawFling(target, duration, isGoon)
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    local trp = target and target:FindFirstChild("HumanoidRootPart")
    if not hrp or not trp then return end
    
    local oldPos = hrp.CFrame
    task.spawn(function()
        local start = tick()
        while tick() - start < duration do
            if hrp and trp then
                -- Pure Physics Glitch: Spin + Velocity
                hrp.CFrame = trp.CFrame * CFrame.Angles(0, math.rad(tick()*5000), 0)
                hrp.Velocity = Vector3.new(99999, 99999, 99999) 
            end
            RunService.Heartbeat:Wait()
        end
        hrp.Velocity = Vector3.new(0,0,0); hrp.CFrame = oldPos
    end)
end


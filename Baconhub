-- // BACON HUB: RAW (LOCK & RUN EDITION) //
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

local Config = { 
    Color = Color3.fromRGB(255, 0, 80), 
    Bg = Color3.fromRGB(10, 10, 10), 
    Accent = Color3.fromRGB(20, 20, 20),
    SoundId = "rbxassetid://110513334295662",
    Speed = 0.8,
    Volume = 3
}

-- // UI CONSTRUCTION //
local Screen = Instance.new("ScreenGui", LocalPlayer.PlayerGui); Screen.Name = "BaconRaw"; Screen.ResetOnSpawn = false
local Main = Instance.new("Frame", Screen); Main.Size = UDim2.new(0, 170, 0, 270); Main.Position = UDim2.new(0.5, -85, 0.5, -135)
Main.BackgroundColor3 = Config.Bg; Instance.new("UICorner", Main); Instance.new("UIStroke", Main).Color = Config.Color

local Title = Instance.new("TextLabel", Main); Title.Size = UDim2.new(1, 0, 0, 35); Title.Text = "BACON HUB"
Title.TextColor3 = Config.Color; Title.Font = Enum.Font.GothamBold; Title.TextSize = 14; Title.BackgroundTransparency = 1

local List = Instance.new("ScrollingFrame", Main); List.Size = UDim2.new(1, -10, 1, -45); List.Position = UDim2.new(0, 5, 0, 40)
List.BackgroundTransparency = 1; List.ScrollBarThickness = 0; Instance.new("UIListLayout", List).Padding = UDim.new(0, 5)

-- // SPRINT UI ELEMENTS //
local SprintLabel = Instance.new("TextLabel", List); SprintLabel.Size = UDim2.new(1, 0, 0, 15)
SprintLabel.Text = "Goon for 15s to unlock"; SprintLabel.TextColor3 = Color3.new(0.6, 0.6, 0.6)
SprintLabel.Font = Enum.Font.Gotham; SprintLabel.TextSize = 10; SprintLabel.BackgroundTransparency = 1

local SprintBtn = Instance.new("TextButton", List); SprintBtn.Size = UDim2.new(1, 0, 0, 40)
SprintBtn.BackgroundColor3 = Config.Accent; SprintBtn.Text = "SPRINT 🔒"; SprintBtn.TextColor3 = Color3.new(0.5, 0.5, 0.5)
SprintBtn.Font = Enum.Font.GothamBold; SprintBtn.TextSize = 12; Instance.new("UICorner", SprintBtn)

-- // DRAGGING //
local function Drag(g)
    local d, s, p; g.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then d = true; s = i.Position; p = g.Position end end)
    UIS.InputChanged:Connect(function(i) if d and i.UserInputType == Enum.UserInputType.MouseMovement then
        local del = i.Position - s; g.Position = UDim2.new(p.X.Scale, p.X.Offset + del.X, p.Y.Scale, p.Y.Offset + del.Y)
    end end)
    UIS.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then d = false end end)
end; Drag(Main)

-- // LOGIC //
local goonActive = false
local goonStartTime = 0
local runUnlocked = false
local MySound = Instance.new("Sound", game:GetService("SoundService"))
MySound.SoundId = Config.SoundId; MySound.Volume = Config.Volume; MySound.PlaybackSpeed = Config.Speed; MySound.Looped = true

-- Unlock Polling
task.spawn(function()
    while task.wait(0.1) do
        if goonActive then
            local elapsed = tick() - goonStartTime
            if elapsed >= 15 then
                runUnlocked = true
                SprintBtn.Text = "SPRINT [E] 🔓"; SprintBtn.TextColor3 = Color3.new(1, 1, 1); SprintLabel.Text = "UNLOCKED!"
            else
                SprintBtn.Text = "SPRINT 🔒 ("..math.floor(15 - elapsed).."s)"; runUnlocked = false
            end
        else
            runUnlocked = false
            SprintBtn.Text = "SPRINT 🔒"; SprintBtn.TextColor3 = Color3.new(0.5, 0.5, 0.5); SprintLabel.Text = "Goon for 15s to unlock"
        end
    end
end)

UIS.InputBegan:Connect(function(i, p)
    if not p and i.KeyCode == Enum.KeyCode.E and runUnlocked then
        local h = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if h then h.WalkSpeed = (h.WalkSpeed == 32) and 16 or 32 end
    end
end)

-- // BUTTONS //
local function AddB(t, c)
    local b = Instance.new("TextButton", List); b.Size = UDim2.new(1, 0, 0, 40)
    b.BackgroundColor3 = Config.Accent; b.Text = t; b.TextColor3 = Color3.new(1,1,1)
    b.Font = Enum.Font.GothamBold; b.TextSize = 12; Instance.new("UICorner", b); b.MouseButton1Click:Connect(c)
end

AddB("ATTACK (INSTANT)", function()
    local n = nil; local d = 100; for _,p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local m = (LocalPlayer.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
            if m < d then d = m; n = p.Character end
        end
    end
    if n then
        local hrp = LocalPlayer.Character.HumanoidRootPart; local old = hrp.CFrame
        hrp.CFrame = n.HumanoidRootPart.CFrame; hrp.Velocity = Vector3.new(99999,99999,99999)
        task.wait(0.3); hrp.Velocity = Vector3.zero; hrp.CFrame = old
    end
end)

local goonBtn = Instance.new("TextButton", List); goonBtn.Size = UDim2.new(1, 0, 0, 40)
goonBtn.BackgroundColor3 = Config.Accent; goonBtn.Text = "GOONING (OFF)"; goonBtn.TextColor3 = Color3.new(1,1,1)
goonBtn.Font = Enum.Font.GothamBold; goonBtn.TextSize = 12; Instance.new("UICorner", goonBtn)

goonBtn.MouseButton1Click:Connect(function()
    goonActive = not goonActive
    goonBtn.Text = goonActive and "GOONING (ON)" or "GOONING (OFF)"
    goonBtn.BackgroundColor3 = goonActive and Config.Color or Config.Accent
    if goonActive then MySound:Play(); goonStartTime = tick() else 
        MySound:Stop(); goonStartTime = 0 
        local h = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if h then h.WalkSpeed = 16 end
    end
    task.spawn(function()
        while goonActive do
            local n = nil; local d = 100; for _,p in pairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    local m = (LocalPlayer.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
                    if m < d then d = m; n = p.Character end
                end
            end
            if n then LocalPlayer.Character.HumanoidRootPart.CFrame = n.HumanoidRootPart.CFrame * CFrame.new(0,0,math.sin(tick()*30)*2) end
            RunService.Heartbeat:Wait()
        end
    end)
end)

-- // DRAGGING FIXED //
local function makeDraggable(gui)
    local dragging, dragStart, startPos
    gui.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; dragStart = input.Position; startPos = gui.Position end
    end)
    UIS.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            gui.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UIS.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
end
makeDraggable(Main)

-- // TARGETING //
local function GetNearest()
    local closest, dist = nil, 50
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local d = (LocalPlayer.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
            if d < dist then dist = d; closest = p.Character end
        end
    end
    return closest
end

-- // FLING ACTIONS WITH SAVE POINT //
local function FlingAction(target, duration)
    if not target or not LocalPlayer.Character then return end
    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    local trp = target:FindFirstChild("HumanoidRootPart")
    
    local savePos = hrp.CFrame -- Save your spot
    
    task.spawn(function()
        local start = tick()
        while tick() - start < duration do
            if hrp and trp then
                hrp.CFrame = trp.CFrame * CFrame.new(0, 0, math.sin(tick() * 65) * 1.2)
                hrp.Velocity = Vector3.new(0, 8000, 0) -- High power fling
            end
            RunService.Heartbeat:Wait()
        end
        hrp.Velocity = Vector3.new(0, 0, 0)
        hrp.CFrame = savePos -- Snap back
    end)
end


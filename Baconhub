                        s.Volume = Config.Vol; s.PlaybackSpeed = Config.Pitch; s.Looped = true; s:Play()
                    end
                    if not p.Character:FindFirstChild("BaconVisual") then
                        local b = Instance.new("Part", p.Character); b.Name = "BaconVisual"; b.Size = Vector3.new(5,7,5)
                        b.Color = Color3.new(1,1,1); b.Transparency = 0.6; b.CanCollide = false; b.Material = Enum.Material.ForceField
                        local w = Instance.new("WeldConstraint", b); w.Part0 = b; w.Part1 = root; b.CFrame = root.CFrame
                    end
                else
                    if root and root:FindFirstChild("SyncAudio") then root.SyncAudio:Destroy() end
                    if p.Character:FindFirstChild("BaconVisual") then p.Character.BaconVisual:Destroy() end
                end
            end
        end
    end
end)


-- // FUNCTIONS //
local function getTarget()
    local text = Input.Text:lower()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Name:lower():find(text) then return p.Character end
    end
    return nil
end

local function addBtn(txt, callback)
    local b = Instance.new("TextButton", List); b.Size = UDim2.new(1, 0, 0, 50)
    b.BackgroundColor3 = Color3.fromRGB(30, 30, 30); b.Text = txt; b.TextColor3 = Color3.new(1, 1, 1)
    b.Font = Enum.Font.GothamBold; b.TextSize = 16; Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(callback)
    return b
end

-- // CORE ACTIONS //
addBtn("ATTACK", function()
    local t = getTarget()
    if t and t:FindFirstChild("HumanoidRootPart") then
        LocalPlayer.Character.HumanoidRootPart.CFrame = t.HumanoidRootPart.CFrame * CFrame.new(0, 0, -2)
    end
end)

addBtn("KICK", function()
    local t = getTarget()
    if t and t:FindFirstChild("HumanoidRootPart") then
        LocalPlayer.Character.HumanoidRootPart.CFrame = t.HumanoidRootPart.CFrame * CFrame.new(0, 0, -1)
    end
end)

local goonActive = false
local goonBtn = addBtn("GOONING", function() end)
goonBtn.MouseButton1Click:Connect(function()
    goonActive = not goonActive
    goonBtn.BackgroundColor3 = goonActive and Config.Color or Color3.fromRGB(30, 30, 30)
    goonBtn.TextColor3 = goonActive and Color3.new(0,0,0) or Color3.new(1,1,1)
    
    task.spawn(function()
        while goonActive do
            local t = getTarget()
            if t and t:FindFirstChild("HumanoidRootPart") and LocalPlayer.Character then
                local offset = math.sin(tick() * 20) * 2
                LocalPlayer.Character.HumanoidRootPart.CFrame = t.HumanoidRootPart.CFrame * CFrame.new(0, 0, offset)
            end
            RunService.Heartbeat:Wait()
        end
    end)
end)


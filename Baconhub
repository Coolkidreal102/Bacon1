List.BackgroundTransparency = 1; List.ScrollBarThickness = 0; 
local layout = Instance.new("UIListLayout", List); layout.Padding = UDim.new(0, 5)

-- // FLING ENGINE //
local function GetNearest()
    local closest, dist = nil, 100
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local d = (LocalPlayer.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
            if d < dist then dist = d; closest = p.Character end
        end
    end
    return closest
end

local function FlingAction(target, duration)
    if not target or not LocalPlayer.Character then return end
    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    local trp = target:FindFirstChild("HumanoidRootPart")
    
    task.spawn(function()
        local start = tick()
        while tick() - start < duration do
            if hrp and trp then
                -- Gooning Movement (Vibration)
                local offset = math.sin(tick() * 50) * 2
                hrp.CFrame = trp.CFrame * CFrame.new(0, 0, offset)
                -- Fling Force
                hrp.Velocity = Vector3.new(0, 100000, 0) + (hrp.CFrame.LookVector * 5000)
            end
            RunService.Heartbeat:Wait()
        end
        hrp.Velocity = Vector3.new(0, 0, 0)
    end)
end

-- // BUTTONS //
local function addBtn(txt, callback)
    local b = Instance.new("TextButton", List); b.Size = UDim2.new(1, 0, 0, 40)
    b.BackgroundColor3 = Color3.fromRGB(35, 35, 35); b.Text = txt; b.TextColor3 = Color3.new(1, 1, 1)
    b.Font = Enum.Font.GothamBold; b.TextSize = 13; Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(callback)
end

addBtn("ATTACK (INSTANT)", function()
    local n = GetNearest()
    if n then FlingAction(n, 0.5) end
end)

addBtn("KICK (3S GOON)", function()
    local n = GetNearest()
    if n then FlingAction(n, 3) end
end)

local goonActive = false
local goonBtn = Instance.new("TextButton", List); goonBtn.Size = UDim2.new(1, 0, 0, 40)
goonBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 35); goonBtn.Text = "GOONING"; goonBtn.TextColor3 = Color3.new(1, 1, 1)
goonBtn.Font = Enum.Font.GothamBold; goonBtn.TextSize = 13; Instance.new("UICorner", goonBtn)
goonBtn.Parent = List

goonBtn.MouseButton1Click:Connect(function()
    goonActive = not goonActive
    goonBtn.BackgroundColor3 = goonActive and Config.Color or Color3.fromRGB(35, 35, 35)
    task.spawn(function()
        while goonActive do
            local n = GetNearest()
            if n and n:FindFirstChild("HumanoidRootPart") and LocalPlayer.Character then
                LocalPlayer.Character.HumanoidRootPart.CFrame = n.HumanoidRootPart.CFrame * CFrame.new(0, 0, math.sin(tick() * 30) * 1.5)
            end
            RunService.Heartbeat:Wait()
        end
    end)
end)

-- // DRAGGING //
local function makeDraggable(gui)
    local dragging, dragStart, startPos
    gui.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = input.Position; startPos = gui.Position
        end
    end)
    UIS.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            gui.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UIS.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
end
makeDraggable(Main)

-- Toggle Menu (Press K)
UIS.InputBegan:Connect(function(i, g) if not g and i.KeyCode == Enum.KeyCode.K then Main.Visible = not Main.Visible end end)

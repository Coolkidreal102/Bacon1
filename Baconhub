-- // ENGINE FUNCTIONS //

local function makeDraggable(obj)
    local dragging, dragStart, startPos
    obj.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; dragStart = input.Position; startPos = obj.Position end
    end)
    UIS.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            obj.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UIS.InputEnded:Connect(function() dragging = false end)
end

local function getTarget()
    local text = Input.Text:lower()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Name:lower():find(text) then return p.Character end
    end
    return nil
end

local function GoonStretch(targetChar, mode)
    local char = LocalPlayer.Character
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local trp = targetChar:FindFirstChild("HumanoidRootPart")
    if not hrp or not trp then return end
    
    local rightLegJoint = char:FindFirstChild("Right Hip", true)
    local armJoint = char:FindFirstChild("Right Shoulder", true)
    local start = tick()

    task.spawn(function()
        while tick() - start < 1.5 and targetChar do
            local offset = math.sin(tick() * 50) * 2
            hrp.CFrame = trp.CFrame * CFrame.new(0, 0, offset)
            hrp.Velocity = Vector3.new(0, 100, 0) -- Force to trigger fling

            if mode == "NOM" and rightLegJoint then
                rightLegJoint.C0 = rightLegJoint.C0:Lerp(CFrame.new(1, -1, -2) * CFrame.Angles(math.rad(-90), 0, 0), 0.5)
            elseif mode == "ATTACK" and armJoint then
                armJoint.C0 = armJoint.C0:Lerp(CFrame.new(1, 0.5, -2) * CFrame.Angles(math.rad(90), 0, 0), 0.5)
            end
            RunService.Heartbeat:Wait()
        end
        -- Reset Joints
        if rightLegJoint then rightLegJoint.C0 = CFrame.new(1, -1, 0) end
        if armJoint then armJoint.C0 = CFrame.new(1, 0.5, 0) end
    end)
end

local function addBtn(txt, callback)
    local b = Instance.new("TextButton", List); b.Size = UDim2.new(1, 0, 0, 45)
    b.BackgroundColor3 = Color3.fromRGB(25,25,25); b.Text = txt; b.TextColor3 = Color3.new(1,1,1)
    b.Font = Enum.Font.GothamBold; b.TextSize = 14; Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(callback)
    return b
end

-- // BUTTONS //
addBtn("ATTACK (FLING)", function() 
    local t = getTarget()
    if t then GoonStretch(t, "ATTACK") end
end)

addBtn("NOM (FLING)", function() 

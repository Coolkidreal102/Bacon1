local function Bub(p, m)
    local h = p.Character and p.Character:FindFirstChild("Head")
    if h then
        local b = Instance.new("BillboardGui", h); b.Size = UDim2.new(0, 150, 0, 40); b.AlwaysOnTop = true; b.ExtentsOffset = Vector3.new(0, 3, 0)
        local t = Instance.new("TextLabel", b); t.Size = UDim2.new(1, 0, 1, 0); t.BackgroundColor3 = Color3.new(0,0,0); t.Text = "💭 "..m; t.TextColor3 = Color3.new(1,1,1); t.TextWrapped = true; Instance.new("UICorner", t)
        local l = Instance.new("TextLabel", C_Log); l.Size = UDim2.new(1, 0, 0, 18); l.Text = p.Name..": "..m; l.TextColor3 = Color3.new(1,1,1); l.BackgroundTransparency = 1; l.TextSize = 10; l.TextXAlignment = "Left"
        task.delay(5, function() b:Destroy() l:Destroy() end)
    end
end

-- Network logic using DisplayName
Ci_Box.FocusLost:Connect(function(e)
    if e and Ci_Box.Text ~= "" then
        local msg = Ci_Box.Text
        local oldName = L.DisplayName
        L.DisplayName = "[BACON]: "..msg
        Bub(L, msg)
        Ci_Box.Text = ""
        task.delay(2, function() L.DisplayName = oldName end)
    end
end)

task.spawn(function()
    while task.wait(0.3) do
        for _, v in pairs(P:GetPlayers()) do
            if v ~= L and v.DisplayName:sub(1,8) == "[BACON]:" then
                local m = v.DisplayName:sub(10)
                Bub(v, m)
            end
        end
    end
end)


-- // WARNING SYSTEM //
local function ShowWarning()
    local WarnFrame = Instance.new("Frame", Screen)
    WarnFrame.Size = UDim2.new(0, 250, 0, 100); WarnFrame.Position = UDim2.new(0.5, -125, 0.4, -50)
    WarnFrame.BackgroundColor3 = Color3.new(0,0,0); Instance.new("UIStroke", WarnFrame).Color = Color3.new(1,0,0)
    
    local txt = Instance.new("TextLabel", WarnFrame); txt.Size = UDim2.new(1, 0, 1, 0); txt.TextWrapped = true
    txt.Text = "WARNING: GOONING SOUNDS ACTIVE. PLEASE LOWER VOLUME IF UNDERAGE."
    txt.TextColor3 = Color3.new(1,1,1); txt.Font = Enum.Font.GothamBold; txt.TextSize = 14; txt.BackgroundTransparency = 1
    
    task.delay(5, function() WarnFrame:Destroy() end)
end

-- // MODEL & AUDIO SYNC //
-- This loop detects OTHER script users
task.spawn(function()
    while task.wait(0.5) do
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local signal = p.Character:FindFirstChild("BaconGoonTag")
                local root = p.Character:FindFirstChild("HumanoidRootPart")
                
                if signal and root then
                    -- Play Sound Locally for you
                    if not root:FindFirstChild("SyncSound") then
                        local s = Instance.new("Sound", root)
                        s.Name = "SyncSound"; s.SoundId = Config.SoundId; s.Volume = Config.Volume
                        s.PlaybackSpeed = Config.PlaybackSpeed; s.Looped = true; s:Play()
                    end
                    -- Show White Model (Only for script users)
                    if not p.Character:FindFirstChild("BaconVisual") then
                        local m = Instance.new("Part", p.Character)
                        m.Name = "BaconVisual"; m.Size = Vector3.new(4, 6, 4)
                        m.Color = Color3.new(1, 1, 1); m.Transparency = 0.5; m.CanCollide = false
                        local weld = Instance.new("WeldConstraint", m)
                        weld.Part0 = m; weld.Part1 = root; m.CFrame = root.CFrame
                    end
                else
                    if root and root:FindFirstChild("SyncSound") then root.SyncSound:Destroy() end
                    if p.Character:FindFirstChild("BaconVisual") then p.Character.BaconVisual:Destroy() end
                end
            end
        end
    end
end)

-- // LOCAL GOONING LOGIC //
local goonActive = false
local MySound = Instance.new("Sound", game:GetService("SoundService"))
MySound.SoundId = Config.SoundId; MySound.Volume = Config.Volume; MySound.PlaybackSpeed = Config.PlaybackSpeed; MySound.Looped = true

local goonBtn = Instance.new("TextButton", List); goonBtn.Size = UDim2.new(1, 0, 0, 40)
goonBtn.BackgroundColor3 = Config.Accent; goonBtn.Text = "GOONING (OFF)"; goonBtn.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", goonBtn)

goonBtn.MouseButton1Click:Connect(function()
    goonActive = not goonActive
    goonBtn.Text = goonActive and "GOONING (ON)" or "GOONING (OFF)"
    goonBtn.BackgroundColor3 = goonActive and Config.Color or Config.Accent
    
    if goonActive then
        ShowWarning()
        MySound:Play()
        -- Create the "Signal" tag
        local tag = Instance.new("BoolValue", LocalPlayer.Character)
        tag.Name = "BaconGoonTag"
    else
        MySound:Stop()
        if LocalPlayer.Character:FindFirstChild("BaconGoonTag") then
            LocalPlayer.Character.BaconGoonTag:Destroy()
        end
    end

    task.spawn(function()
        while goonActive do
            -- Find target
            local target = nil
            local dist = 100
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    local d = (LocalPlayer.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
                    if d < dist then dist = d; target = p.Character end
                end
            end
            -- Orbit Logic
            if target and target:FindFirstChild("HumanoidRootPart") and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                LocalPlayer.Character.HumanoidRootPart.CFrame = target.HumanoidRootPart.CFrame * CFrame.new(0, 0, math.sin(tick() * 30) * 2)
            end
            RunService.Heartbeat:Wait()
        end
    end)
end)
